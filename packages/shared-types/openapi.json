{"openapi": "3.1.0", "info": {"title": "Time Internet Retention API", "version": "0.9.0"}, "paths": {"/api/health": {"get": {"tags": ["health"], "summary": "Health", "description": "Liveness probe; also reports the active LLM mode (mock|gemini).", "operationId": "health_api_health_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HealthResponse"}}}}}}}, "/api/customers": {"get": {"tags": ["customers"], "summary": "List Customers", "operationId": "list_customers_api_customers_get", "parameters": [{"name": "search", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "description": "matches name or customer id", "title": "Search"}, "description": "matches name or customer id"}, {"name": "plan", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "description": "filter by plan id", "title": "Plan"}, "description": "filter by plan id"}, {"name": "sort", "in": "query", "required": false, "schema": {"enum": ["tenure", "avg_gb", "contract_end_date"], "type": "string", "default": "contract_end_date", "title": "Sort"}}, {"name": "order", "in": "query", "required": false, "schema": {"enum": ["asc", "desc"], "type": "string", "default": "asc", "title": "Order"}}, {"name": "page", "in": "query", "required": false, "schema": {"type": "integer", "minimum": 1, "default": 1, "title": "Page"}}, {"name": "page_size", "in": "query", "required": false, "schema": {"type": "integer", "maximum": 100, "minimum": 1, "default": 20, "title": "Page Size"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/Page_CustomerSummary_"}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/customers/{customer_id}": {"get": {"tags": ["customers"],