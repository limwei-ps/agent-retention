# Copy to .env for local dev. Never commit the real .env.
LLM_MODE=mock                 # mock | gemini

# Gemini runs on Vertex AI via Application Default Credentials — no API key.
# For gemini mode: set the project below, then run `gcloud auth application-default login`
# (locally) or rely on the Cloud Run service-account identity (deployed).
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
# GEMINI_TIMEOUT_S=30         # per-chunk stall timeout before failing over to the next hop

DATABASE_URL=sqlite:///./retention.db
APP_TIMEZONE=Asia/Kuala_Lumpur
BULK_CONCURRENCY=4
